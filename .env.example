# Garmin Connect Credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# PostgreSQL / TimescaleDB
# When running in Docker, these are overridden by docker-compose.yml
# (POSTGRES_HOST=timescaledb, MONGO_HOST=mongodb)
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=garmin
POSTGRES_USER=garmin
POSTGRES_PASSWORD=CHANGE_ME

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=garmin_raw
MONGO_ROOT_USER=garmin
MONGO_ROOT_PASSWORD=CHANGE_ME

# Polling
POLL_INTERVAL_MINUTES=10
BACKFILL_DAYS=30

# Grafana
GRAFANA_PASSWORD=CHANGE_ME
GRAFANA_PORT=3001

# MCP Server
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_API_KEY=CHANGE_ME

# Run scripts/generate-secrets.sh to generate random values for all CHANGE_ME fields
