# Garmin Connect Credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# PostgreSQL / TimescaleDB
# When running in Docker, these are overridden by docker-compose.yml
# (POSTGRES_HOST=timescaledb, MONGO_HOST=mongodb)
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=garmin
POSTGRES_USER=garmin
POSTGRES_PASSWORD=garmin_secret

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=garmin_raw

# Polling
POLL_INTERVAL_MINUTES=10
BACKFILL_DAYS=30

# MCP
MCP_TRANSPORT=stdio
