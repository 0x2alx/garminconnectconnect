            "lineWidth": 0
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, floors_climbed FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10m",
  "schemaVersion": 39,
  "tags": ["garmin", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
