{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Daily Steps",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "barAlignment": 0,
            "lineWidth": 0,
            "pointSize": 5,
            "stacking": { "mode": "none" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "green", "value": 10000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, total_steps FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Daily Calories",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "barAlignment": 0,
            "lineWidth": 0,
            "pointSize": 5,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "active_calories" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "bmr_calories" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, active_calories, bmr_calories FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Resting Heart Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "pointSize": 5
          },
          "unit": "bpm"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, resting_heart_rate FROM daily_summary WHERE $__timeFilter(date) AND resting_heart_rate IS NOT NULL ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Heart Rate Intraday",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 15,
            "pointSize": 1
          },
          "unit": "bpm"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS time, heart_rate FROM heart_rate WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Stress Level Intraday",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "min": 0,
          "max": 100,
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS time, stress_level FROM stress WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Body Battery",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "scheme"
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS time, level AS body_battery FROM body_battery WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "SpO2",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 5
          },
          "min": 85,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS time, spo2_value FROM spo2 WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Sleep Duration & Stages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "barAlignment": 0,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          },
          "unit": "h"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "deep" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "light" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rem" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, deep_sleep_seconds/3600.0 AS deep, light_sleep_seconds/3600.0 AS light, rem_sleep_seconds/3600.0 AS rem FROM sleep_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Sleep Score & HRV",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sleep_score" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "unit", "value": "short" },
              { "id": "custom.axisLabel", "value": "Sleep Score" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "hrv" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "ms" },
              { "id": "custom.axisLabel", "value": "HRV (ms)" }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, sleep_score FROM sleep_summary WHERE $__timeFilter(date) AND sleep_score IS NOT NULL ORDER BY date",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date AS time, last_night_avg AS hrv FROM hrv WHERE $__timeFilter(date) AND last_night_avg IS NOT NULL ORDER BY date",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "Training Readiness",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "barAlignment": 0,
            "lineWidth": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, score FROM training_readiness WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "HRV Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "pointSize": 5
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "weekly_avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "solid" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "last_night_avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, weekly_avg, last_night_avg FROM hrv WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Average Stress",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme",
            "barAlignment": 0,
            "lineWidth": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, avg_stress FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Respiration Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "super-light-green", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
