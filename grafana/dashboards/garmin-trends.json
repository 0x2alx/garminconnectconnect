{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Steps (7-day avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, AVG(total_steps) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS steps_7d_avg FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Resting HR (7-day avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "bpm"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, AVG(resting_heart_rate) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS rhr_7d_avg FROM daily_summary WHERE $__timeFilter(date) AND resting_heart_rate IS NOT NULL ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Stress (7-day avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, AVG(avg_stress) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS stress_7d_avg FROM daily_summary WHERE $__timeFilter(date) AND avg_stress IS NOT NULL ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Sleep Duration (7-day avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "dark-blue", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "h"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, AVG(total_sleep_seconds/3600.0) OVER (ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS sleep_hours_7d FROM sleep_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Sleep vs Body Battery",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sleep_hours" },
            "properties": [
              { "id": "custom.drawStyle", "value": "bars" },
              { "id": "custom.fillOpacity", "value": 50 },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "body_battery_high" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, total_sleep_seconds/3600.0 AS sleep_hours FROM sleep_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date AS time, body_battery_high FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Training Readiness Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sleep_score" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "recovery_score" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "hrv_score" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, sleep_score, recovery_score, hrv_score FROM training_readiness WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "HRV with Baseline Band",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "last_night_avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "baseline_high" },
            "properties": [
              { "id": "custom.fillBelowTo", "value": "baseline_low" },
              { "id": "custom.fillOpacity", "value": 15 },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "baseline_low" },
            "properties": [
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, last_night_avg FROM hrv WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date AS time, baseline_low FROM hrv WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "B"
        },
        {
          "rawSql": "SELECT date AS time, baseline_high FROM hrv WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Body Composition",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "always",
            "pointSize": 5,
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "weight_kg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "body_fat_pct" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, weight_kg FROM body_composition WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT date AS time, body_fat_pct FROM body_composition WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Intensity Minutes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "min"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "moderate_intensity_minutes" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "vigorous_intensity_minutes" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT date AS time, moderate_intensity_minutes, vigorous_intensity_minutes FROM daily_summary WHERE $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Running Pace Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "showPoints": "always",
            "spanNulls": false
          },
          "unit": "min/km",
          "custom.axisPlacement": "auto"
        },
        "overrides": []
      },
      "options": {
        "yAxis": {
          "reverse": true
        }
      },
      "targets": [
        {
          "rawSql": "SELECT start_time AS time, CASE WHEN distance_meters > 0 THEN (duration_seconds / 60.0) / (distance_meters / 1000.0) ELSE NULL END AS pace_min_per_km FROM activities WHERE $__timeFilter(start_time) AND activity_type IN ('running', 'treadmill_running') AND distance_meters > 1000 ORDER BY start_time",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Activity Calories Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "unit": "kcal"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT start_time AS time, calories FROM activities WHERE $__timeFilter(start_time) ORDER BY start_time",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Sync Status",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT metric_name AS metric, MAX(date) AS last_synced, COUNT(*) FILTER (WHERE status = 'completed') AS completed, COUNT(*) FILTER (WHERE status = 'failed') AS failed FROM sync_status GROUP BY metric_name ORDER BY metric_name",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["garmin", "trends"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
